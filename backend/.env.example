# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Supabase Project URL
# Get from: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Anon/Public Key (for client-side auth)
# Get from: Supabase Dashboard → Settings → API → Project API keys → anon/public
SUPABASE_KEY=your-anon-key-here

# Service Role Key (REQUIRED for backend - has elevated permissions)
# Get from: Supabase Dashboard → Settings → API → Project API keys → service_role
# ⚠️ SECURITY WARNING: Keep secret - bypasses Row Level Security (RLS)
# ⚠️ Used for: Supabase Storage uploads, admin operations, system instructions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret for validating user tokens
# Get from: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ============================================================================
# AI SERVICES
# ============================================================================

# Anthropic Claude API
# Get from: https://console.anthropic.com/settings/keys
# Used for: Chat responses, RAG
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Voyage AI API (for embeddings)
# Get from: https://dash.voyageai.com/api-keys
# Used for: Document embeddings, semantic search
VOYAGE_API_KEY=pa-your-voyage-key-here

# ============================================================================
# GOOGLE DRIVE INTEGRATION (Optional - for document sync feature)
# ============================================================================

# Google Cloud OAuth 2.0 Credentials
# Setup: https://console.cloud.google.com
# 1. Create/select project
# 2. Enable Google Drive API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized redirect URIs (see below)
# 5. Copy Client ID and Secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# OAuth Redirect URI (must match Google Cloud Console exactly)
# Development: http://localhost:3000/api/auth/google/callback
# Production: https://yourdomain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Encryption key for storing OAuth tokens securely
# Generate with: openssl rand -hex 32
# Keep this secret and never commit to git
OAUTH_ENCRYPTION_KEY=your-64-character-hex-key-here

# Optional: Your user ID for initial testing
# Get from Supabase: SELECT id FROM users WHERE email = 'your-email@example.com';
# Used for debugging/testing the sync feature
PAIGE_USER_ID=your-user-id-from-supabase

# ============================================================================
# NOTION INTEGRATION (Optional - for document sync feature)
# ============================================================================

# Notion OAuth 2.0 Credentials
# Setup: https://www.notion.so/my-integrations
# 1. Create new integration
# 2. Configure OAuth settings
# 3. Set Redirect URI (see below)
# 4. Copy OAuth client ID and secret
# 5. Grant permissions: Read content
NOTION_CLIENT_ID=your-notion-oauth-client-id
NOTION_CLIENT_SECRET=secret_your-notion-oauth-client-secret

# OAuth Redirect URI (must match Notion integration settings exactly)
# Development: http://localhost:8000/api/notion/callback
# Production: https://your-api-domain.com/api/notion/callback
NOTION_REDIRECT_URI=http://localhost:8000/api/notion/callback

# ============================================================================
# EMAIL NOTIFICATIONS (Optional - graceful fallback if not configured)
# ============================================================================

# Resend API for admin notifications
# Get from: https://resend.com/api-keys
# If not set: Notifications logged to console only (no emails sent)
RESEND_API_KEY=re_your-resend-api-key

# Email address to send from
# For testing: onboarding@resend.dev (works immediately, 100/day limit)
# For production: noreply@yourdomain.com (requires domain verification in Resend)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Frontend URL for CORS (comma-separated for multiple environments)
# Example: http://localhost:3000,https://your-production-domain.vercel.app
FRONTEND_URL=http://localhost:3000,https://your-production-domain.vercel.app

# ============================================================================
# SINGLE-TENANT MODE (Optional - defaults shown)
# ============================================================================

# Default client ID for single-tenant deployments
# This well-known UUID is used when no client_id is specified
# IMPORTANT: Must match the UUID created by database migration
DEFAULT_CLIENT_ID=00000000-0000-0000-0000-000000000001

# Organization name (used in system instructions and UI)
CLIENT_NAME=Your Organization

# AI Assistant name
ASSISTANT_NAME=Thesis

# ============================================================================
# VOLUME STORAGE (Railway/Docker Deployments)
# ============================================================================

# Path to persistent volume mount (e.g., /data on Railway)
# Only needed if using Railway volumes or Docker volumes
# Leave empty for local development
VOLUME_PATH=

# Optional: File-based logging (uses volume path if set)
# If not set: Logs only go to console/stdout (recommended for Railway)
# If set with VOLUME_PATH: LOG_FILE=/data/logs/app.log
# If set without VOLUME_PATH: LOG_FILE=logs/app.log (local directory)
# Note: File logging has automatic rotation (10MB max, 5 backups)
LOG_FILE=

# ============================================================================
# REDIS CACHE (Optional - for performance optimization)
# ============================================================================

# Redis URL for caching (optional)
# If not set: Caching disabled (graceful fallback)
# Local: redis://localhost:6379
# Railway: redis://default:password@redis.railway.internal:6379
# Format: redis://[user]:[password]@[host]:[port]/[db]
REDIS_URL=redis://localhost:6379

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
LOG_LEVEL=INFO

# ============================================================================
# HELP SYSTEM (AI-Powered Documentation Chat)
# ============================================================================

# Help System Reindex Webhook Key
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Used for: Securing the help documentation reindex webhook endpoint
# Required for: Auto-reindexing when help docs change via GitHub Actions
HELP_REINDEX_API_KEY=

# ============================================================================
# NEO4J KNOWLEDGE GRAPH (Optional - for stakeholder network analysis)
# ============================================================================

# Neo4j Aura Connection URI
# Get from: Neo4j Aura Console → Instance → Connection tab
# Format: neo4j+s://[instance-id].databases.neo4j.io
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io

# Neo4j Password
# Get from: Neo4j Aura Console (shown when instance is created)
NEO4J_PASSWORD=your-neo4j-password

# Neo4j Username (usually "neo4j" for Aura)
NEO4J_USERNAME=neo4j

# Neo4j Database name (usually "neo4j" for Aura)
NEO4J_DATABASE=neo4j
