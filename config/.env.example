# Thesis - Environment Variables

# ============================================================================
# SINGLE-TENANT MODE CONFIGURATION
# ============================================================================

# Default client ID for single-tenant deployments
# This well-known UUID is used when no client_id is specified
# IMPORTANT: Must match the UUID created by database migration
DEFAULT_CLIENT_ID=00000000-0000-0000-0000-000000000001

# Organization name (used in system instructions and UI)
CLIENT_NAME=Your Organization

# AI Assistant name
ASSISTANT_NAME=Thesis

# Enable/disable multi-tenant features (set to 'true' to re-enable clients)
MULTI_TENANT_MODE=false

# ============================================================================
# DATABASE (Supabase)
# ============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Service Role Key (REQUIRED for backend - has elevated permissions)
# Get from: Supabase Dashboard → Settings → API → service_role key
# ⚠️ SECURITY: Keep secret - bypasses Row Level Security (RLS)
# ⚠️ Used for: Supabase Storage uploads, admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# AI SERVICES
# ============================================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Voyage AI Embeddings
VOYAGE_API_KEY=your-voyage-api-key


# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000,https://your-app.vercel.app

# Rate limiting
DEFAULT_RATE_LIMIT=100/minute
CHAT_RATE_LIMIT=20/minute
UPLOAD_RATE_LIMIT=10/minute

# File upload limits
MAX_UPLOAD_SIZE_MB=50

# ============================================================================
# EMAIL NOTIFICATIONS (Optional - graceful fallback if not configured)
# ============================================================================

# Resend API for admin notifications when interviews complete
# Get from: https://resend.com/api-keys
# If not set: Notifications logged to console only (no emails sent)
RESEND_API_KEY=re_your-resend-api-key

# Email address to send from (must be verified domain or use resend.dev)
# For testing: onboarding@resend.dev (works immediately, 100/day limit)
# For production: noreply@yourdomain.com (requires domain verification)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================================================
# ERROR TRACKING (Optional - Sentry)
# ============================================================================

# Sentry for production error monitoring and tracking
# Get from: https://sentry.io/ (create account and project)
# If not set: Errors only logged to console (no remote tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================

# Feature flags
ENABLE_VOICE_INTERVIEWS=true
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_SYSTEM_INSTRUCTIONS=true

# ============================================================================
# VOLUME STORAGE (Railway/Docker Deployments)
# ============================================================================

# Path to persistent volume mount (e.g., /data on Railway)
# Only needed if using Railway volumes or Docker volumes
# Leave empty for local development
VOLUME_PATH=

# Optional: File-based logging (uses volume path if set)
# If not set: Logs only go to console/stdout (recommended)
# If set with VOLUME_PATH: LOG_FILE=/data/logs/app.log
# If set without VOLUME_PATH: LOG_FILE=logs/app.log (local directory)
LOG_FILE=
